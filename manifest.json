  "changelog": [
    {
      "version": "2.0.0",
      "date": "2026-06-28",
      "summary": "Install system. Shareable /install URL served by the Workbench worker. Email-gated scaffold proxy (/api/scaffold/*) — approved emails get files, others get a request queued. Invite codes (single/multi-use, expiry, auto-approve on redemption). Super admin system (SUPER_ADMIN_EMAILS secret, separate ⚡ Super Admin tab). Admin → Invites tab: send invites with email + code, approve pending requests, manage active codes. Email notifications via Resend (workbench@carbonet.app). Install log table tracks per-project installs for future licensing. workbench-install.md updated to 10-step flow including preview page copy (Step 7)."
    },
    {
      "version": "1.9.0",
      "date": "2026-06-17",
      "summary": "Generic blank-slate install. No CarboNet app bundled. Canvas preview now iframes the connected app URL (set in Settings → Connections). ConnectedAppSection added to Connections tab. GET/PUT /app-api/connected-app routes added. Manifest trimmed to Workbench-only files."
    },
    {
      "version": "1.8.7",
      "date": "2026-06-16",
      "summary": "WorkflowButton on EquipmentList. Revert smoke-tested. Workflow templates: design_workflow_templates table, 6 built-in templates, CRUD routes, Templates panel in workflow sidebar."
    },
    {
      "version": "1.8.6",
      "date": "2026-06-15",
      "summary": "Phase 3: Workflow AI routes fixed. Per-workflow settings drawer. Context freshness badge. Auto-scan on panel open. Route ordering lesson documented."
    },
    {
      "version": "1.8.5",
      "date": "2026-06-15",
      "summary": "Edits panel merged Queue + History. Rail reordered. Turn counter atomic CTE. Agent action auto-dispatch bug fixed."
    },
    {
      "version": "1.8.4",
      "date": "2026-06-15",
