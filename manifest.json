  "changelog": [
    { "version": "2.7.0", "date": "2026-07-05", "summary": "Gap #2 REV7 — console-verified /update + C3 live-version gate. Installer self-sources expected hashes (no seal key); scaffold proxy locked to an allowlist pinned at manifest-hashes.commit with server-side served-vs-pin verification; /update reseeded to fetch via the installer proxy, then gate 'done' on the installer-owned sweep (C2) AND off-platform GitHub-Action fingerprint check (C3) reading the edge-stamped x-g3-app-version. Version bumped to force the update to run on installs already labelled 2.6.0. manifest-hashes pinned to 90bce90 (bundles NOT regenerated this release; source-bundle-2.ts is 1 commit stale vs source — affects fresh-install /build reconstruction only, tracked separately)." },
    { "version": "2.6.0", "date": "2026-07-03", "summary": "Gap #1 fix — delivery kit reconstruction. Added real app_files array (was missing entirely) reflecting the M1 modular backend: server.ts + all 11 routes/*.ts (incl. console.ts/console-hash.ts), source-bundle*.ts, and full client/preview file set. Added scripts/generate-source-bundles.mjs (repo-side, deterministic, round-trip-verified, LF-only) so source-bundle*.ts are generated from main instead of hand-maintained; regenerated all three bundles to include the previously-missing modular routes (fixes fresh installs shipping a pre-M1 backendless app). Fixed design_file_cache DDL drift in github/workbench-install.md (path/content/updated_at + UNIQUE(org_id,path), plus design_orgs.proxy_paths heal) to match code." },
    { "version": "2.5.6", "date": "2026-07-01", "summary": "HOTFIX — /update renamed to /pull-scaffold with response fingerprinting and network-call gate. Agents were short-circuiting the multi-step /update command. Fix: (1) renamed primary command to /pull-scaffold; (2) hard-coded network gate at step 1 requiring javascript tool fetch; (3) fingerprint requirement — reply must include manifest.updated_at verbatim. /update and /sync kept as aliases. Install doc seed SQL uses DO UPDATE so re-runs patch existing installs." },
    { "version": "2.5.5", "date": "2026-07-09", "summary": "isOwner gate on GitHub tab verified. License version badge updates on /pull-scaffold runs." },
    { "version": "2.5.4", "date": "2026-07-09", "summary": "GitHub tab hidden on installed copies via isOwner gate (GLIDEOS_ACCESS_TOKEN present). /update pings license endpoint after run." },
    { "version": "2.5.3", "date": "2026-07-08", "summary": "Installer-proxied /update — no PAT required." },
    { "version": "2.5.2", "date": "2026-07-01", "summary": "Two-repo GitHub split. Install doc + manifest served from public repo." },
